# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/frida_domaincheck

# Test Database (overrides DATABASE_URL for e2e tests)
TEST_DATABASE_URL=

# Authentication
JWT_SECRET=your-secret-here

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Cyber-Vorabcheck

# PGP Encryption
PGP_PASSPHRASE=
PGP_PRIVATE_KEY=
PGP_PUBLIC_KEY=

# Cysmo API (Domain Checking)
# Base URL for the Cysmo OAuth token endpoint (used for client_credentials grant)
CYSMO_API_BASE_URL=https://api.cysmo.com
# OAuth 2.0 client_credentials: client ID (obtained from Cysmo portal)
CYSMO_CLIENT_ID=
# OAuth 2.0 client_credentials: client secret (obtained from Cysmo portal)
CYSMO_CLIENT_SECRET=

# OAuth (falls back to CYSMO_* vars if unset)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Encryption (AES-256-GCM for API credentials at rest)
# Must be 64 hex characters, or leave blank to derive from JWT_SECRET
ENCRYPTION_KEY=

# Base URL for public-facing links (password reset, registration)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Set to "true" to use fixture validation instead of real connections
# for API credential test-connection (auto-enabled when CYSMO vars unset)
TEST_CONNECTION_FIXTURE=false

# Cron
CRON_SECRET=
